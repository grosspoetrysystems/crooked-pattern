{
  "name": "@grosspoetrysystems/crooked-pattern",
  "version": "0.1.1",
  "description": "Crooked Pattern \u2014 Agentic Readiness Score (ARS) scanner, CLI + MCP server",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "agentic-readiness",
    "ars",
    "mcp",
    "scanner",
    "supply-chain",
    "llms-txt"
  ],
  "type": "module",
  "packageManager": "pnpm@10.12.1",
  "files": ["dist", "CHANGELOG.md"],
  "bin": {
    "ars": "./dist/cli.js",
    "crooked-pattern": "./dist/cli.js",
    "ars-mcp": "./dist/mcp.js"
  },
  "exports": {
    "./mcp": "./dist/mcp.js"
  },
  "scripts": {
    "build": "tsup",
    "smoke": "pnpm build && node dist/cli.js --help && node dist/cli.js scan --source . --out .tempor/smoke-source",
    "verify": "pnpm check && pnpm lint && pnpm test && pnpm build && pnpm smoke && pnpm knip",
    "check": "tsc --noEmit",
    "ars": "tsx src/bin/cli.ts",
    "dev": "tsx src/bin/cli.ts",
    "scan": "tsx src/bin/cli.ts scan",
    "diff": "tsx src/bin/cli.ts diff",
    "lint": "biome check src package.json tsconfig.json tsup.config.ts vitest.config.ts vitest.global-setup.ts knip.config.ts commitlint.config.js biome.jsonc",
    "format": "biome check --write src package.json tsconfig.json tsup.config.ts vitest.config.ts vitest.global-setup.ts knip.config.ts commitlint.config.js biome.jsonc",
    "test": "vitest run",
    "coverage": "vitest run --coverage",
    "knip": "knip",
    "prepare": "lefthook install"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "commander": "^12.1.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.4",
    "@commitlint/cli": "^19.6.1",
    "@commitlint/config-conventional": "^19.6.0",
    "@types/node": "^22.10.2",
    "@vitest/coverage-v8": "^2.1.8",
    "knip": "^5.40.0",
    "lefthook": "^1.9.14",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "ultracite": "^4.2.10",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=20"
  },
  "author": "Gross Poetry Systems",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/grosspoetrysystems/crooked-pattern.git"
  },
  "homepage": "https://github.com/grosspoetrysystems/crooked-pattern#readme",
  "bugs": {
    "url": "https://github.com/grosspoetrysystems/crooked-pattern/issues"
  }
}
