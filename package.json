{
  "name": "ars",
  "version": "0.1.0",
  "description": "Agentic Readiness Score CLI",
  "type": "module",
  "packageManager": "pnpm@10.12.1",
  "bin": {
    "ars": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsup",
    "smoke": "pnpm build && node dist/cli.js --help && node dist/cli.js scan --source . --out .tempor/smoke-source",
    "verify": "pnpm check && pnpm lint && pnpm test && pnpm build && pnpm smoke && pnpm knip",
    "check": "tsc --noEmit",
    "ars": "tsx src/bin/cli.ts",
    "dev": "tsx src/bin/cli.ts",
    "scan": "tsx src/bin/cli.ts scan",
    "diff": "tsx src/bin/cli.ts diff",
    "lint": "ultracite lint",
    "format": "ultracite format",
    "test": "vitest run",
    "coverage": "vitest run --coverage",
    "knip": "knip",
    "prepare": "lefthook install"
  },
  "dependencies": {
    "commander": "^12.1.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.6.1",
    "@commitlint/config-conventional": "^19.6.0",
    "@types/node": "^22.10.2",
    "@vitest/coverage-v8": "^2.1.8",
    "knip": "^5.40.0",
    "lefthook": "^1.9.14",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "ultracite": "^4.2.10",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=20"
  }
}
